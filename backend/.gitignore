# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc

# ── Virtual Environments ──────────────────────────────────────────────────────
venv/
env/
.env/
.venv/
ENV/

# ── Environment Variables ─────────────────────────────────────────────────────
.env
*.env
!.env.example

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
pharmacy_dev.db

# ── Flask / Migrations ────────────────────────────────────────────────────────
instance/
migrations/versions/*.py
!migrations/versions/.gitkeep

# ── Uploads ───────────────────────────────────────────────────────────────────
uploads/prescriptions/*
!uploads/prescriptions/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

